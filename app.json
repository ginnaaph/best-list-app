{
  "expo": {
    "name": "best-list-app",
    "slug": "best-list-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/BestList1.png",
    "scheme": "bestlistapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8F8F7",
        "foregroundImage": "./assets/BestList1.png",
        "monochromeImage": "./assets/BestList1.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/BestList1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/BestListFull.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#F8F8F7",
          "dark": {
            "backgroundColor": "#1A1A1A"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
