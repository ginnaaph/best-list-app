{
  "expo": {
    "name": "BestList.",
    "slug": "BestList.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/BestList1.png",
    "scheme": "bestlist",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gina.bestlist",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8F8F7",
        "foregroundImage": "./assets/BestList1.png",
        "monochromeImage": "./assets/BestList1.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/BestList1.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F0E8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
